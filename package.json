{
  "name": "gulp-zopfli-green",
  "version": "7.0.0",
  "description": "Updated Zopfli compressor for gulp",
  "type": "commonjs",
  "keywords": [
    "gulpplugin",
    "zopfli",
    "compress",
    "deflate",
    "gzip",
    "gulp"
  ],
  "homepage": "https://github.com/gekorm/gulp-zopfli-green",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gekorm/gulp-zopfli-green.git"
  },
  "author": "George Kormaris <npm@gekorm.com>",
  "scripts": {
    "release": "yarn exec npm publish --provenance --access public",
    "stylecheck": "prettier . --check",
    "test": "NODE_ENV=test mocha -R spec",
    "test:cover": "nyc --reporter=lcov --reporter=text mocha -R xunit --reporter-option output=../coverage/test-results.xml"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "lib",
    "LICENSE",
    "package.json",
    "index.js",
    "README.md"
  ],
  "contributors": [
    "Pierre Inglebert <pierre.inglebert@gmail.com>",
    "Mayhem <stepien.nicolas@gmail.com>",
    "TruongSinh Tran-Nguyen <i@truongsinh.pro>",
    "Romeo Van Snick <romeovs@gmail.com>",
    "Jeremy Stuckey <jeremystuckey@gmail.com>"
  ],
  "dependencies": {
    "@gfx/zopfli": "^1.0.15",
    "bytes": "^3.1.2",
    "plugin-error": "^2.0.1",
    "stream-to-array": "^2.3.0",
    "through2": "^4.0.2"
  },
  "devDependencies": {
    "coveralls": "^3.1.1",
    "graceful-fs": "^4.2.11",
    "gulp": "^5.0.1",
    "gulp-rename": "^2.1.0",
    "gulp-tap": "^2.0.0",
    "mocha": "^11.7.5",
    "nid": "^2.0.1",
    "nyc": "^18.0.0",
    "prettier": "^3.8.1",
    "should": "^13.2.3"
  },
  "resolutions": {
    "graceful-fs": "4.2.11"
  },
  "main": "index.js",
  "licenses": [
    {
      "type": "MIT",
      "url": "http://github.com/pierreinglebert/gulp-gzip/raw/master/LICENSE"
    }
  ],
  "packageManager": "yarn@4.12.0"
}
